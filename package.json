{
  "name": "advanced-typescript-kata",
  "version": "1.0.0",
  "private": true,
  "description": "Advanced TypeScript exercises / kata that reinforce strong fundamentals and modern best practices.",
  "type": "module",
  "scripts": {
    "typecheck": "tsc -p tsconfig.solutions.json --noEmit",
    "verify": "tsc -p tsconfig.solutions.json --noEmit && vitest run",
    "check": "node scripts/check.mjs",
    "check:problem": "tsc --noEmit",
    "run": "tsx",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "expect-type": "^1.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
