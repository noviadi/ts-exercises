{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@lib": ["./src/lib.ts"]
    }
  },
  // The root config is what your EDITOR uses: it type-checks every file,
  // including the `*.problem.ts` starters, so you get inline errors that guide
  // you to the TODOs. To verify the worked solutions (clean baseline) run
  // `npm run typecheck`, which uses tsconfig.solutions.json instead.
  "include": ["src/**/*.ts", "topics/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
